{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Json2",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "select1"
				},
				{
					"name": "surrogateKey1"
				},
				{
					"name": "rank1"
				},
				{
					"name": "cast1"
				},
				{
					"name": "sort1"
				},
				{
					"name": "cast2"
				}
			],
			"scriptLines": [
				"parameters{",
				"     numpartition as integer (2)",
				"}",
				"source(output(",
				"          cid as integer,",
				"          custid as integer,",
				"          call_dur as integer,",
				"          cost as double,",
				"          insertdt as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     enableCdc: true,",
				"     mode: 'read',",
				"     skipInitialLoad: false,",
				"     waterMarkColumn: 'cid',",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     partitionBy('roundRobin', ($numpartition))) ~> source1",
				"source1 filter(greaterOrEqual(call_dur,401)) ~> filter1",
				"filter1 select(mapColumn(",
				"          cid,",
				"          custid,",
				"          cost,",
				"          calldur = call_dur,",
				"          insertdt,",
				"          loaddt = insertdt",
				"     ),",
				"     partitionBy('hash', ($numpartition),",
				"          custid",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> select1",
				"select1 keyGenerate(output(custsk as long),",
				"     startAt: 100L,",
				"     stepValue: 1L) ~> surrogateKey1",
				"surrogateKey1 rank(desc(calldur, true),",
				"     output(calldur_rnk as long)) ~> rank1",
				"rank1 cast(output(",
				"          loaddt as string",
				"     ),",
				"     errors: false) ~> cast1",
				"cast2 sort(asc(calldur_rnk, true)) ~> sort1",
				"cast1 cast(output(",
				"          loaddt as date 'yyyy-MM-dd'",
				"     ),",
				"     errors: true) ~> cast2",
				"sort1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}